<UserControl
    x:Class="QemuWG.ui.QemuToolsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:QemuWG.data">

    <TabView Margin="14" IsAddTabButtonVisible="False" SelectedIndex="0">
        <TabViewItem Header="{Binding [tools.qemuIo], Source={StaticResource Strings}}" IsClosable="False">
            <Grid Padding="8" ColumnSpacing="10" RowSpacing="8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="0.3*" /><ColumnDefinition Width="0.7*" /></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Grid Grid.ColumnSpan="2" ColumnSpacing="8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="0.7*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="IoImageBox" Header="{Binding [tools.image], Source={StaticResource Strings}}" /><Button Grid.Column="1" VerticalAlignment="Bottom" Click="BrowseIoImage_Click" CornerRadius="6"><SymbolIcon Symbol="Folder" /></Button></Grid>
                    <TextBox x:Name="IoFormatBox" Grid.Column="1" Header="{Binding [tools.format], Source={StaticResource Strings}}" />
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Orientation="Horizontal" Spacing="6"><Button x:Name="RunIoButton" Click="RunIoButton_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}"><StackPanel Orientation="Horizontal" Spacing="7"><SymbolIcon Symbol="Play" /><TextBlock x:Name="RunIoButtonText" Text="{Binding [tools.run], Source={StaticResource Strings}}" /></StackPanel></Button><Button x:Name="CancelIoButton" Click="CancelIoButton_Click" CornerRadius="6" Visibility="Collapsed"><SymbolIcon Symbol="Cancel" /></Button></StackPanel>
                </Grid>
                <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><AutoSuggestBox x:Name="IoSearchBox" Margin="8" PlaceholderText="{Binding [tools.command], Source={StaticResource Strings}}" TextChanged="IoSearchBox_TextChanged" /><ListView x:Name="IoCommandList" Grid.Row="1" Margin="6,0,6,6" Background="Transparent" BorderThickness="0" SelectionChanged="IoCommandList_SelectionChanged"><ListView.ItemTemplate><DataTemplate x:DataType="models:QemuIoCmdInfo"><StackPanel Padding="5,3"><TextBlock FontFamily="Cascadia Mono, Consolas" Text="{x:Bind Name}" /><TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Syntax}" TextTrimming="CharacterEllipsis" /></StackPanel></DataTemplate></ListView.ItemTemplate></ListView></Grid>
                </Border>
                <Grid Grid.Row="1" Grid.Column="1" RowSpacing="8">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBox x:Name="IoCommandBox" Header="{Binding [tools.command], Source={StaticResource Strings}}" FontFamily="Cascadia Mono, Consolas" />
                    <Grid Grid.Row="1" ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><ComboBox x:Name="IoCacheCombo" Header="{Binding [tools.cache], Source={StaticResource Strings}}"><x:String>writeback</x:String><x:String>none</x:String><x:String>writethrough</x:String><x:String>directsync</x:String><x:String>unsafe</x:String></ComboBox><ComboBox x:Name="IoAioCombo" Grid.Column="1" Header="{Binding [tools.aio], Source={StaticResource Strings}}"><x:String>threads</x:String><x:String>native</x:String><x:String>io_uring</x:String></ComboBox><ComboBox x:Name="IoDiscardCombo" Grid.Column="2" Header="{Binding [tools.discard], Source={StaticResource Strings}}"><x:String>ignore</x:String><x:String>unmap</x:String></ComboBox></Grid>
                    <Grid Grid.Row="2" ColumnSpacing="8" RowSpacing="6"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><ToggleSwitch x:Name="IoReadOnlyToggle" Header="{Binding [tools.readOnly], Source={StaticResource Strings}}" /><ToggleSwitch x:Name="IoSnapshotToggle" Grid.Column="1" Header="{Binding [tools.snapshot], Source={StaticResource Strings}}" /><ToggleSwitch x:Name="IoNoCacheToggle" Grid.Column="2" Header="{Binding [tools.noCache], Source={StaticResource Strings}}" /><ToggleSwitch x:Name="IoCopyOnReadToggle" Grid.Row="1" Header="{Binding [tools.copyOnRead], Source={StaticResource Strings}}" /><ToggleSwitch x:Name="IoForceShareToggle" Grid.Row="1" Grid.Column="1" Header="{Binding [tools.forceShare], Source={StaticResource Strings}}" /></Grid>
                    <Grid Grid.Row="3"><TextBox x:Name="IoOutputBox" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas" FontSize="11" IsReadOnly="True" TextWrapping="Wrap" /><ProgressRing x:Name="IoProgress" Width="28" Height="28" IsActive="False" Visibility="Collapsed" /></Grid>
                </Grid>
            </Grid>
        </TabViewItem>

        <TabViewItem Header="{Binding [tools.edid], Source={StaticResource Strings}}" IsClosable="False">
            <Grid Padding="12" ColumnSpacing="10" RowSpacing="10">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <TextBox x:Name="EdidVendorBox" Header="{Binding [tools.vendor], Source={StaticResource Strings}}" MaxLength="3" /><TextBox x:Name="EdidNameBox" Grid.Column="1" Header="{Binding [tools.monitorName], Source={StaticResource Strings}}" /><TextBox x:Name="EdidSerialBox" Grid.Column="2" Header="{Binding [tools.serial], Source={StaticResource Strings}}" />
                <NumberBox x:Name="EdidDpiBox" Grid.Row="1" Header="{Binding [tools.dpi], Source={StaticResource Strings}}" Value="96" /><NumberBox x:Name="EdidPreferredWidthBox" Grid.Row="1" Grid.Column="1" Header="{Binding [tools.preferredWidth], Source={StaticResource Strings}}" Value="1920" /><NumberBox x:Name="EdidPreferredHeightBox" Grid.Row="1" Grid.Column="2" Header="{Binding [tools.preferredHeight], Source={StaticResource Strings}}" Value="1080" />
                <NumberBox x:Name="EdidMaximumWidthBox" Grid.Row="2" Grid.Column="1" Header="{Binding [tools.maximumWidth], Source={StaticResource Strings}}" Value="1920" /><NumberBox x:Name="EdidMaximumHeightBox" Grid.Row="2" Grid.Column="2" Header="{Binding [tools.maximumHeight], Source={StaticResource Strings}}" Value="1080" />
                <Grid Grid.Row="3" Grid.ColumnSpan="3" ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="EdidOutputBox" Header="{Binding [tools.outputFile], Source={StaticResource Strings}}" /><Button Grid.Column="1" VerticalAlignment="Bottom" Click="BrowseEdidOutput_Click" CornerRadius="6"><SymbolIcon Symbol="Folder" /></Button><Button Grid.Column="2" VerticalAlignment="Bottom" Click="GenerateEdidButton_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}"><TextBlock Text="{Binding [tools.generate], Source={StaticResource Strings}}" /></Button></Grid>
                <Grid Grid.Row="4" Grid.ColumnSpan="3"><TextBox x:Name="EdidResultBox" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas" IsReadOnly="True" TextWrapping="Wrap" /><ProgressRing x:Name="EdidProgress" Width="28" Height="28" IsActive="False" Visibility="Collapsed" /></Grid>
            </Grid>
        </TabViewItem>

        <TabViewItem Header="{Binding [tools.nbdServer], Source={StaticResource Strings}}" IsClosable="False">
            <Grid Padding="12" ColumnSpacing="10" RowSpacing="8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Grid Grid.ColumnSpan="3" ColumnSpacing="6"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="NbdImageBox" Header="{Binding [tools.image], Source={StaticResource Strings}}" /><Button Grid.Column="1" VerticalAlignment="Bottom" Click="BrowseNbdImage_Click" CornerRadius="6"><SymbolIcon Symbol="Folder" /></Button></Grid>
                <TextBox x:Name="NbdBindBox" Grid.Row="1" Header="{Binding [tools.bindAddress], Source={StaticResource Strings}}" Text="127.0.0.1" /><NumberBox x:Name="NbdPortBox" Grid.Row="1" Grid.Column="1" Header="{Binding [tools.port], Source={StaticResource Strings}}" Minimum="1" Maximum="65535" Value="10809" /><NumberBox x:Name="NbdSharedBox" Grid.Row="1" Grid.Column="2" Header="{Binding [tools.maxClients], Source={StaticResource Strings}}" Minimum="1" Maximum="1024" Value="1" />
                <TextBox x:Name="NbdFormatBox" Grid.Row="2" Header="{Binding [tools.format], Source={StaticResource Strings}}" /><TextBox x:Name="NbdExportNameBox" Grid.Row="2" Grid.Column="1" Header="{Binding [tools.exportName], Source={StaticResource Strings}}" /><TextBox x:Name="NbdDescriptionBox" Grid.Row="2" Grid.Column="2" Header="{Binding [tools.description], Source={StaticResource Strings}}" />
                <ComboBox x:Name="NbdCacheCombo" Grid.Row="3" Header="{Binding [tools.cache], Source={StaticResource Strings}}"><x:String>writeback</x:String><x:String>none</x:String><x:String>writethrough</x:String><x:String>directsync</x:String><x:String>unsafe</x:String></ComboBox><ComboBox x:Name="NbdAioCombo" Grid.Row="3" Grid.Column="1" Header="{Binding [tools.aio], Source={StaticResource Strings}}"><x:String>threads</x:String><x:String>native</x:String><x:String>io_uring</x:String></ComboBox><ComboBox x:Name="NbdDiscardCombo" Grid.Row="3" Grid.Column="2" Header="{Binding [tools.discard], Source={StaticResource Strings}}"><x:String>ignore</x:String><x:String>unmap</x:String></ComboBox>
                <Grid Grid.Row="4" Grid.ColumnSpan="3" ColumnSpacing="10" RowSpacing="6"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><ToggleSwitch x:Name="NbdReadOnlyToggle" Header="{Binding [tools.readOnly], Source={StaticResource Strings}}" /><ToggleSwitch x:Name="NbdSnapshotToggle" Grid.Column="1" Header="{Binding [tools.snapshot], Source={StaticResource Strings}}" /><ToggleSwitch x:Name="NbdPersistentToggle" Grid.Column="2" Header="{Binding [tools.persistent], Source={StaticResource Strings}}" /><ToggleSwitch x:Name="NbdAllocationDepthToggle" Grid.Row="1" Header="{Binding [tools.allocationDepth], Source={StaticResource Strings}}" /><ToggleSwitch x:Name="NbdVerboseToggle" Grid.Row="1" Grid.Column="1" Header="{Binding [tools.verbose], Source={StaticResource Strings}}" /></Grid>
                <Grid Grid.Row="5" Grid.ColumnSpan="3"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="NbdExtraBox" Header="{Binding [tools.extraArguments], Source={StaticResource Strings}}" /><Button Grid.Column="1" VerticalAlignment="Bottom" Click="StartNbd_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}"><TextBlock Text="{Binding [tools.start], Source={StaticResource Strings}}" /></Button><Button Grid.Column="2" VerticalAlignment="Bottom" Click="StopNbd_Click" CornerRadius="6"><TextBlock Text="{Binding [tools.stop], Source={StaticResource Strings}}" /></Button></Grid><TextBox x:Name="NbdOutputBox" Grid.Row="1" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas" FontSize="11" IsReadOnly="True" TextWrapping="Wrap" /></Grid>
            </Grid>
        </TabViewItem>

        <TabViewItem Header="{Binding [tools.storageDaemon], Source={StaticResource Strings}}" IsClosable="False">
            <Grid Padding="12" ColumnSpacing="10" RowSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><TextBox x:Name="StorageBlockdevBox" Header="--blockdev" PlaceholderText="driver=file,node-name=file0,filename=disk.qcow2" /><TextBox x:Name="StorageNbdServerBox" Grid.Column="1" Header="--nbd-server" Text="addr.type=inet,addr.host=127.0.0.1,addr.port=10809" /><TextBox x:Name="StorageExportBox" Grid.Row="1" Header="--export" PlaceholderText="type=nbd,id=export0,node-name=disk0,writable=off" /><TextBox x:Name="StorageMonitorBox" Grid.Row="1" Grid.Column="1" Header="--monitor" /><TextBox x:Name="StorageChardevBox" Grid.Row="2" Header="--chardev" /><TextBox x:Name="StorageObjectsBox" Grid.Row="2" Grid.Column="1" Header="--object" PlaceholderText="{Binding [tools.semicolonSeparated], Source={StaticResource Strings}}" /><TextBox x:Name="StoragePidFileBox" Grid.Row="3" Header="--pidfile" /><StackPanel Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Orientation="Horizontal" Spacing="6"><Button Click="StartStorageDaemon_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}"><TextBlock Text="{Binding [tools.start], Source={StaticResource Strings}}" /></Button><Button Click="StopStorageDaemon_Click" CornerRadius="6"><TextBlock Text="{Binding [tools.stop], Source={StaticResource Strings}}" /></Button></StackPanel><TextBox x:Name="StorageOutputBox" Grid.Row="4" Grid.ColumnSpan="2" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas" FontSize="11" IsReadOnly="True" TextWrapping="Wrap" /></Grid>
        </TabViewItem>

        <TabViewItem Header="{Binding [tools.services], Source={StaticResource Strings}}" IsClosable="False">
            <Grid Padding="12" RowSpacing="10">
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="140" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <ComboBox x:Name="ServiceToolCombo" Header="{Binding [tools.tool], Source={StaticResource Strings}}" HorizontalAlignment="Stretch" SelectionChanged="ServiceToolCombo_SelectionChanged"><x:String>qemu-nbd.exe</x:String><x:String>qemu-storage-daemon.exe</x:String></ComboBox>
                <TextBox x:Name="ServiceArgumentsBox" Grid.Row="1" AcceptsReturn="True" Header="{Binding [tools.arguments], Source={StaticResource Strings}}" FontFamily="Cascadia Mono, Consolas" TextWrapping="Wrap" />
                <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="6"><Button x:Name="RunToolOnceButton" Click="RunToolOnce_Click" CornerRadius="6"><TextBlock Text="{Binding [tools.runOnce], Source={StaticResource Strings}}" /></Button><Button Click="StartTool_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}"><TextBlock Text="{Binding [tools.start], Source={StaticResource Strings}}" /></Button><Button Click="StopTool_Click" CornerRadius="6"><TextBlock Text="{Binding [tools.stop], Source={StaticResource Strings}}" /></Button><Button Click="ClearToolOutput_Click" CornerRadius="6" ToolTipService.ToolTip="{Binding [tools.clear], Source={StaticResource Strings}}"><FontIcon Glyph="&#xE74D;" /></Button></StackPanel>
                <TextBox x:Name="ServiceOutputBox" Grid.Row="3" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas" FontSize="11" IsReadOnly="True" TextWrapping="Wrap" />
            </Grid>
        </TabViewItem>
    </TabView>
</UserControl>

