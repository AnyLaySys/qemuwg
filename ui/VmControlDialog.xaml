<ContentDialog
    x:Class="QemuWG.ui.VmControlDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:QemuWG.data"
    CloseButtonText="{Binding [common.done], Source={StaticResource Strings}}">
    <ContentDialog.Resources><x:Double x:Key="ContentDialogMaxWidth">1080</x:Double></ContentDialog.Resources>
    <Grid Margin="0,8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" RowSpacing="10">
        <Grid.RowDefinitions><RowDefinition Height="76" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,8"><StackPanel Spacing="2"><TextBlock FontSize="11" Text="{Binding [qmp.status], Source={StaticResource Strings}}" /><TextBlock x:Name="StatusValue" FontSize="17" FontWeight="SemiBold" /></StackPanel></Border>
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,8"><StackPanel Spacing="2"><TextBlock FontSize="11" Text="{Binding [qmp.cpus], Source={StaticResource Strings}}" /><TextBlock x:Name="CpuValue" FontSize="17" FontWeight="SemiBold" /></StackPanel></Border>
            <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,8"><StackPanel Spacing="2"><TextBlock FontSize="11" Text="{Binding [qmp.memory], Source={StaticResource Strings}}" /><TextBlock x:Name="MemoryValue" FontSize="17" FontWeight="SemiBold" /></StackPanel></Border>
            <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12,8"><StackPanel Spacing="2"><TextBlock FontSize="11" Text="{Binding [qmp.blockDevices], Source={StaticResource Strings}}" /><TextBlock x:Name="BlockValue" FontSize="17" FontWeight="SemiBold" /></StackPanel></Border>
            <Button Grid.Column="4" VerticalAlignment="Stretch" Click="RefreshButton_Click" CornerRadius="6" ToolTipService.ToolTip="{Binding [qmp.refresh], Source={StaticResource Strings}}"><SymbolIcon Symbol="Refresh" /></Button>
        </Grid>

        <TabView Grid.Row="1" IsAddTabButtonVisible="False">
            <TabViewItem Header="{Binding [qmp.controls], Source={StaticResource Strings}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Padding="8" ColumnSpacing="10" RowSpacing="10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="1.35*" /></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
                        <StackPanel Spacing="10"><TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [qmp.power], Source={StaticResource Strings}}" /><Grid ColumnSpacing="6" RowSpacing="6"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><Button Click="PauseButton_Click" CornerRadius="6"><StackPanel Orientation="Horizontal" Spacing="7"><SymbolIcon Symbol="Pause" /><TextBlock Text="{Binding [qmp.pause], Source={StaticResource Strings}}" /></StackPanel></Button><Button Grid.Column="1" Click="ResumeButton_Click" CornerRadius="6"><StackPanel Orientation="Horizontal" Spacing="7"><SymbolIcon Symbol="Play" /><TextBlock Text="{Binding [qmp.resume], Source={StaticResource Strings}}" /></StackPanel></Button><Button Grid.Row="1" Click="ResetButton_Click" CornerRadius="6"><StackPanel Orientation="Horizontal" Spacing="7"><SymbolIcon Symbol="Refresh" /><TextBlock Text="{Binding [qmp.reset], Source={StaticResource Strings}}" /></StackPanel></Button><Button Grid.Row="1" Grid.Column="1" Click="PowerdownButton_Click" CornerRadius="6"><StackPanel Orientation="Horizontal" Spacing="7"><FontIcon Glyph="&#xE7E8;" /><TextBlock Text="{Binding [qmp.powerdown], Source={StaticResource Strings}}" /></StackPanel></Button><Button x:Name="ForceStopControlButton" Grid.Row="2" Grid.ColumnSpan="2" Click="ForceStopControl_Click" CornerRadius="6"><StackPanel Orientation="Horizontal" Spacing="7"><SymbolIcon Symbol="Stop" /><TextBlock x:Name="ForceStopControlText" Text="{Binding [main.forceStop], Source={StaticResource Strings}}" /></StackPanel></Button></Grid></StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
                        <StackPanel Spacing="10"><TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [qmp.keyboard], Source={StaticResource Strings}}" /><Grid ColumnSpacing="6"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Button Click="CtrlAltDelete_Click" CornerRadius="6">Ctrl + Alt + Del</Button><Button Grid.Column="1" Click="CtrlShiftEscape_Click" CornerRadius="6">Ctrl + Shift + Esc</Button><Button Grid.Column="2" Click="AltF4_Click" CornerRadius="6">Alt + F4</Button><Button Grid.Column="3" Click="WinR_Click" CornerRadius="6">Win + R</Button></Grid><Grid ColumnSpacing="6"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><CheckBox x:Name="CtrlKeyBox" Content="Ctrl" /><CheckBox x:Name="AltKeyBox" Grid.Column="1" Content="Alt" /><CheckBox x:Name="ShiftKeyBox" Grid.Column="2" Content="Shift" /><CheckBox x:Name="MetaKeyBox" Grid.Column="3" Content="Win" /><ComboBox x:Name="KeyCombo" Grid.Column="4" PlaceholderText="{Binding [qmp.key], Source={StaticResource Strings}}" IsEditable="True" /><Button Grid.Column="5" Click="SendCustomKey_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}"><TextBlock Text="{Binding [qmp.send], Source={StaticResource Strings}}" /></Button></Grid><NumberBox x:Name="HoldTimeBox" Header="{Binding [qmp.holdTime], Source={StaticResource Strings}}" Minimum="1" Maximum="5000" Value="100" SpinButtonPlacementMode="Compact" /></StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
                        <StackPanel Spacing="10"><TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [qmp.diagnostics], Source={StaticResource Strings}}" /><Button Click="NmiButton_Click" CornerRadius="6"><TextBlock Text="{Binding [qmp.injectNmi], Source={StaticResource Strings}}" /></Button><Button Click="ScreenshotButton_Click" CornerRadius="6"><StackPanel Orientation="Horizontal" Spacing="7"><FontIcon Glyph="&#xE722;" /><TextBlock Text="{Binding [qmp.screenshot], Source={StaticResource Strings}}" /></StackPanel></Button><TextBlock x:Name="ScreenshotPathText" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" /></StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [qmp.activity], Source={StaticResource Strings}}" /><Grid Grid.Row="1"><TextBox x:Name="ControlOutputBox" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas" FontSize="11" IsReadOnly="True" TextWrapping="Wrap" /><ProgressRing x:Name="ControlBusyRing" Width="28" Height="28" IsActive="False" Visibility="Collapsed" /></Grid></Grid>
                    </Border>
                    <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
                        <StackPanel Spacing="8"><TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [qmp.opticalMedia], Source={StaticResource Strings}}" /><Grid ColumnSpacing="6"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="MediaPathBox" PlaceholderText="ISO / IMG" /><Button Grid.Column="1" Click="BrowseMedia_Click" CornerRadius="6"><SymbolIcon Symbol="Folder" /></Button></Grid><StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="6"><Button Click="EjectMedia_Click" CornerRadius="6"><TextBlock Text="{Binding [qmp.eject], Source={StaticResource Strings}}" /></Button><Button Click="MountMedia_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}"><TextBlock Text="{Binding [qmp.mount], Source={StaticResource Strings}}" /></Button></StackPanel></StackPanel>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
                        <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><StackPanel Spacing="8"><TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [qmp.memoryBalloon], Source={StaticResource Strings}}" /><NumberBox x:Name="BalloonMemoryBox" Header="{Binding [qmp.targetMemoryMb], Source={StaticResource Strings}}" Minimum="128" Maximum="1048576" Value="4096" SpinButtonPlacementMode="Compact" /><Button HorizontalAlignment="Right" Click="ApplyBalloon_Click" CornerRadius="6"><TextBlock Text="{Binding [qmp.apply], Source={StaticResource Strings}}" /></Button></StackPanel><StackPanel Grid.Column="1" Spacing="8"><TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [qmp.snapshot], Source={StaticResource Strings}}" /><TextBox x:Name="SnapshotNameBox" PlaceholderText="snapshot-1" /><StackPanel Orientation="Horizontal" Spacing="5"><Button Click="SaveSnapshot_Click" CornerRadius="6"><TextBlock Text="{Binding [qmp.snapshotSave], Source={StaticResource Strings}}" /></Button><Button Click="LoadSnapshot_Click" CornerRadius="6"><TextBlock Text="{Binding [qmp.snapshotLoad], Source={StaticResource Strings}}" /></Button><Button Click="DeleteSnapshot_Click" CornerRadius="6"><TextBlock Text="{Binding [qmp.snapshotDelete], Source={StaticResource Strings}}" /></Button></StackPanel></StackPanel></Grid>
                    </Border>
                </Grid></ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [qmp.advanced], Source={StaticResource Strings}}">
                <Grid Padding="8" ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="250" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><AutoSuggestBox x:Name="SearchBox" Margin="8" PlaceholderText="{Binding [qmp.search], Source={StaticResource Strings}}" TextChanged="SearchBox_TextChanged" /><TextBlock x:Name="CommandCountText" Grid.Row="1" Margin="12,0,12,5" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /><ListView x:Name="CommandList" Grid.Row="2" Margin="6,0,6,6" Background="Transparent" BorderThickness="0" SelectionChanged="CommandList_SelectionChanged"><ListView.ItemTemplate><DataTemplate x:DataType="models:QmpCmdInfo"><TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="12" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" /></DataTemplate></ListView.ItemTemplate></ListView></Grid></Border>
                    <Grid Grid.Column="1" RowSpacing="8"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="110" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock FontSize="11" Text="{Binding [qmp.command], Source={StaticResource Strings}}" /><TextBox x:Name="CommandBox" FontFamily="Cascadia Mono, Consolas" TextChanged="CommandBox_TextChanged" /></StackPanel><Button Grid.Column="1" VerticalAlignment="Bottom" Click="ExecuteButton_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}"><StackPanel Orientation="Horizontal" Spacing="7"><SymbolIcon Symbol="Play" /><TextBlock Text="{Binding [common.execute], Source={StaticResource Strings}}" /></StackPanel></Button></Grid><StackPanel Grid.Row="1"><TextBlock FontSize="11" Text="{Binding [qmp.schema], Source={StaticResource Strings}}" /><TextBlock x:Name="SchemaHintText" FontFamily="Cascadia Mono, Consolas" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" /></StackPanel><StackPanel Grid.Row="2"><TextBlock FontSize="11" Text="{Binding [qmp.arguments], Source={StaticResource Strings}}" /><TextBox x:Name="ArgumentsBox" Height="88" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas" Text="{}" TextWrapping="Wrap" /></StackPanel><Grid Grid.Row="3"><TextBlock FontWeight="SemiBold" Text="{Binding [qmp.result], Source={StaticResource Strings}}" /><ProgressRing x:Name="BusyRing" HorizontalAlignment="Right" Width="18" Height="18" IsActive="False" /></Grid><TextBox x:Name="OutputBox" Grid.Row="4" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas" FontSize="11" IsReadOnly="True" TextWrapping="Wrap" /></Grid>
                </Grid>
            </TabViewItem>
        </TabView>
    </Grid>
</ContentDialog>
