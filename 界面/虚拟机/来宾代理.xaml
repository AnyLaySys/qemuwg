<ContentDialog
    x:Class="QemuWG.界面.来宾代理界面"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:数据="using:QemuWG.数据"
    CloseButtonText="{Binding [common.done], Source={StaticResource Strings}}">
    <ContentDialog.Resources><x:Double x:Key="ContentDialogMaxWidth">1040</x:Double></ContentDialog.Resources>
    <Grid Margin="0,8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" RowSpacing="8">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <InfoBar x:Name="ConnectionInfo" IsClosable="False" IsOpen="True" Severity="Informational" Title="{Binding [guestAgent.status], Source={StaticResource Strings}}" />
        <TabView Grid.Row="1" IsAddTabButtonVisible="False">
            <TabViewItem Header="{Binding [guestAgent.overview], Source={StaticResource Strings}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Padding="8" ColumnSpacing="10" RowSpacing="10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="14"><StackPanel Spacing="6"><TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [guestAgent.systemInfo], Source={StaticResource Strings}}" /><TextBlock x:Name="SystemInfoText" TextWrapping="Wrap" /></StackPanel></Border>
                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="14"><StackPanel Spacing="6"><TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [guestAgent.users], Source={StaticResource Strings}}" /><TextBlock x:Name="UsersText" TextWrapping="Wrap" /></StackPanel></Border>
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="14"><StackPanel Spacing="6"><TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [guestAgent.networkInfo], Source={StaticResource Strings}}" /><TextBlock x:Name="NetworkText" FontFamily="Cascadia Mono, Consolas" FontSize="11" TextWrapping="Wrap" /></StackPanel></Border>
                    <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="14"><StackPanel Spacing="6"><TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [guestAgent.diskInfo], Source={StaticResource Strings}}" /><TextBlock x:Name="DisksText" FontFamily="Cascadia Mono, Consolas" FontSize="11" TextWrapping="Wrap" /></StackPanel></Border>
                    <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="14"><Grid ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel Spacing="3"><TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [guestAgent.maintenance], Source={StaticResource Strings}}" /><TextBlock x:Name="FsStateText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"><Button Click="Freeze_Click" CornerRadius="6"><TextBlock Text="{Binding [guestAgent.freeze], Source={StaticResource Strings}}" /></Button><Button Click="Thaw_Click" CornerRadius="6"><TextBlock Text="{Binding [guestAgent.thaw], Source={StaticResource Strings}}" /></Button><Button Click="Trim_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}"><TextBlock Text="{Binding [guestAgent.trim], Source={StaticResource Strings}}" /></Button></StackPanel></Grid></Border>
                </Grid></ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [guestAgent.processes], Source={StaticResource Strings}}">
                <Grid Padding="12" RowSpacing="10"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><TextBox x:Name="ProcessPathBox" Header="{Binding [guestAgent.program], Source={StaticResource Strings}}" PlaceholderText="C:\Windows\System32\cmd.exe" /><TextBox x:Name="ProcessArgumentsBox" Grid.Row="1" Header="{Binding [guestAgent.programArguments], Source={StaticResource Strings}}" PlaceholderText="/c ver" /><Grid Grid.Row="2"><ToggleSwitch x:Name="CaptureOutputToggle" Header="{Binding [guestAgent.captureOutput], Source={StaticResource Strings}}" IsOn="True" /><Button x:Name="RunProcessButton" HorizontalAlignment="Right" Click="RunProcess_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}"><StackPanel Orientation="Horizontal" Spacing="7"><SymbolIcon Symbol="Play" /><TextBlock Text="{Binding [guestAgent.runProgram], Source={StaticResource Strings}}" /></StackPanel></Button></Grid><Grid Grid.Row="3"><TextBox x:Name="ProcessOutputBox" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas" FontSize="11" IsReadOnly="True" TextWrapping="Wrap" /><ProgressRing x:Name="ProcessProgress" Width="30" Height="30" IsActive="False" Visibility="Collapsed" /></Grid></Grid>
            </TabViewItem>

            <TabViewItem Header="{Binding [guestAgent.files], Source={StaticResource Strings}}">
                <Grid Padding="12" RowSpacing="10"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><Grid ColumnSpacing="6"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="HostFileBox" Header="{Binding [guestAgent.hostFile], Source={StaticResource Strings}}" /><Button Grid.Column="1" VerticalAlignment="Bottom" Click="BrowseHostFile_Click" CornerRadius="6"><SymbolIcon Symbol="Folder" /></Button></Grid><TextBox x:Name="GuestFileBox" Grid.Row="1" Header="{Binding [guestAgent.guestPath], Source={StaticResource Strings}}" PlaceholderText="C:\Temp\file.bin" /><StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="6"><Button x:Name="UploadButton" Click="Upload_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}"><TextBlock Text="{Binding [guestAgent.upload], Source={StaticResource Strings}}" /></Button><Button x:Name="DownloadButton" Click="Download_Click" CornerRadius="6"><TextBlock Text="{Binding [guestAgent.download], Source={StaticResource Strings}}" /></Button></StackPanel><Grid Grid.Row="3"><TextBox x:Name="FileOutputBox" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas" FontSize="11" IsReadOnly="True" TextWrapping="Wrap" /><ProgressRing x:Name="FileProgress" Width="30" Height="30" IsActive="False" Visibility="Collapsed" /></Grid></Grid>
            </TabViewItem>

            <TabViewItem Header="{Binding [guestAgent.advanced], Source={StaticResource Strings}}">
                <Grid Padding="8" ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="280" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><AutoSuggestBox x:Name="SearchBox" Margin="8" PlaceholderText="{Binding [guestAgent.search], Source={StaticResource Strings}}" TextChanged="SearchBox_TextChanged" /><ListView x:Name="CommandList" Grid.Row="1" Margin="6,0,6,6" Background="Transparent" BorderThickness="0" SelectionChanged="CommandList_SelectionChanged"><ListView.ItemTemplate><DataTemplate x:DataType="数据:来宾代理命令"><TextBlock Padding="5,4" FontFamily="Cascadia Mono, Consolas" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" /></DataTemplate></ListView.ItemTemplate></ListView></Grid></Border><Grid Grid.Column="1" RowSpacing="8"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="130" /><RowDefinition Height="*" /></Grid.RowDefinitions><Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="CommandBox" Header="{Binding [guestAgent.command], Source={StaticResource Strings}}" FontFamily="Cascadia Mono, Consolas" /><Button x:Name="ExecuteButton" Grid.Column="1" VerticalAlignment="Bottom" Click="ExecuteButton_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}"><TextBlock x:Name="ExecuteButtonText" Text="{Binding [common.execute], Source={StaticResource Strings}}" /></Button></Grid><TextBox x:Name="ArgumentsBox" Grid.Row="1" AcceptsReturn="True" Header="{Binding [guestAgent.arguments], Source={StaticResource Strings}}" FontFamily="Cascadia Mono, Consolas" PlaceholderText="{}" TextWrapping="Wrap" TextChanged="ArgumentsBox_TextChanged" /><Grid Grid.Row="2"><TextBox x:Name="OutputBox" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas" FontSize="11" IsReadOnly="True" TextWrapping="Wrap" /><ProgressRing x:Name="Progress" Width="30" Height="30" IsActive="False" Visibility="Collapsed" /></Grid></Grid></Grid>
            </TabViewItem>
        </TabView>
    </Grid>
</ContentDialog>
