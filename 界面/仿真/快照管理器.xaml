<ContentDialog
    x:Class="QemuWG.界面.快照管理器"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:界面="using:QemuWG.界面"
    CornerRadius="9"
    CloseButtonText="{Binding [common.done], Source={StaticResource Strings}}">
    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1080</x:Double>
    </ContentDialog.Resources>

    <Grid x:Name="RootLayout" Padding="9" RowSpacing="9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center" Spacing="2">
                <TextBlock x:Name="MachineNameText" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="SummaryText" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <Button
                x:Name="RefreshButton"
                Grid.Column="1"
                Click="RefreshButton_Click"
                CornerRadius="3"
                Style="{StaticResource 正方形按钮样式}"
                ToolTipService.ToolTip="{Binding [snapshot.refresh], Source={StaticResource Strings}}">
                <SymbolIcon Symbol="Refresh" />
            </Button>
        </Grid>

        <Grid
            x:Name="Workspace"
            Grid.Row="1"
            ColumnSpacing="9"
            RowSpacing="9"
            SizeChanged="Workspace_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="330" />
                <ColumnDefinition x:Name="DetailColumn" Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TreeRow" Height="*" />
                <RowDefinition x:Name="DetailRow" Height="0" />
            </Grid.RowDefinitions>

            <Border
                x:Name="TreeCard"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Margin="9,9,9,6" FontSize="15" FontWeight="SemiBold" Text="{Binding [snapshot.tree], Source={StaticResource Strings}}" />
                    <ListView
                        x:Name="SnapshotList"
                        Grid.Row="1"
                        Margin="3,0,3,3"
                        Background="Transparent"
                        BorderThickness="0"
                        IsItemClickEnabled="False"
                        SelectionChanged="SnapshotList_SelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="界面:快照树项">
                                <Grid MinHeight="48" Margin="{Binding 缩进}" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Foreground="{Binding 图标颜色}"
                                        Glyph="{Binding 图标}" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding 标题}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding 副标题}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Border
                                        Grid.Column="2"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                        CornerRadius="3"
                                        Visibility="{Binding 当前标记可见}">
                                        <TextBlock FontSize="10" Text="{Binding [snapshot.current], Source={StaticResource Strings}}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <ScrollViewer
                x:Name="DetailScrollViewer"
                Grid.Column="1"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="9">
                    <Border
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="9">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding [snapshot.createTitle], Source={StaticResource Strings}}" />
                            <TextBox
                                x:Name="SnapshotNameBox"
                                Header="{Binding [snapshot.name], Source={StaticResource Strings}}"
                                MaxLength="80"
                                PlaceholderText="{Binding [snapshot.namePlaceholder], Source={StaticResource Strings}}"
                                TextChanged="SnapshotNameBox_TextChanged" />
                            <TextBox
                                x:Name="SnapshotDescriptionBox"
                                AcceptsReturn="True"
                                Header="{Binding [snapshot.description], Source={StaticResource Strings}}"
                                MaxHeight="120"
                                MaxLength="1000"
                                PlaceholderText="{Binding [snapshot.descriptionPlaceholder], Source={StaticResource Strings}}"
                                TextWrapping="Wrap" />
                            <Grid ColumnSpacing="9">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    x:Name="CreateHintText"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding [snapshot.createHint], Source={StaticResource Strings}}"
                                    TextWrapping="Wrap" />
                                <Button
                                    x:Name="CreateButton"
                                    Grid.Column="1"
                                    Click="CreateButton_Click"
                                    CornerRadius="6"
                                    IsEnabled="False"
                                    Style="{StaticResource AccentButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                        <SymbolIcon Symbol="Add" />
                                        <TextBlock Text="{Binding [snapshot.create], Source={StaticResource Strings}}" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="9">
                        <Grid>
                            <StackPanel x:Name="NoSelectionPanel" MinHeight="170" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                <FontIcon HorizontalAlignment="Center" FontSize="28" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE7B8;" />
                                <TextBlock FontWeight="SemiBold" Text="{Binding [snapshot.selectPrompt], Source={StaticResource Strings}}" />
                                <TextBlock MaxWidth="360" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding [snapshot.selectPromptDetail], Source={StaticResource Strings}}" TextAlignment="Center" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel x:Name="SnapshotDetailPanel" Spacing="9" Visibility="Collapsed">
                                <Grid ColumnSpacing="9">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="DetailNameText" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock x:Name="DetailStatusText" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Button
                                            x:Name="RestoreButton"
                                            Click="RestoreButton_Click"
                                            CornerRadius="3"
                                            Style="{StaticResource 正方形按钮样式}"
                                            ToolTipService.ToolTip="{Binding [snapshot.restore], Source={StaticResource Strings}}">
                                            <FontIcon Glyph="&#xE777;" />
                                        </Button>
                                        <Button
                                            x:Name="DeleteButton"
                                            Click="DeleteButton_Click"
                                            CornerRadius="3"
                                            Style="{StaticResource 正方形按钮样式}"
                                            ToolTipService.ToolTip="{Binding [snapshot.delete], Source={StaticResource Strings}}">
                                            <SymbolIcon Symbol="Delete" />
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <TextBlock x:Name="DetailDescriptionText" TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12" RowSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding [snapshot.createdAt], Source={StaticResource Strings}}" />
                                    <TextBlock x:Name="DetailCreatedAtText" Grid.Column="1" />
                                    <TextBlock Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding [snapshot.memoryState], Source={StaticResource Strings}}" />
                                    <TextBlock x:Name="DetailMemoryText" Grid.Row="1" Grid.Column="1" />
                                    <TextBlock Grid.Row="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding [snapshot.vmClock], Source={StaticResource Strings}}" />
                                    <TextBlock x:Name="DetailClockText" Grid.Row="2" Grid.Column="1" />
                                    <TextBlock Grid.Row="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding [snapshot.internalId], Source={StaticResource Strings}}" />
                                    <TextBlock x:Name="DetailTagText" Grid.Row="3" Grid.Column="1" FontFamily="Cascadia Mono, Consolas" FontSize="11" TextTrimming="CharacterEllipsis" />
                                </Grid>

                                <InfoBar x:Name="SnapshotProblemBar" IsClosable="False" IsOpen="False" Severity="Warning" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        x:Name="ConfirmationBar"
                        Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                        BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="9"
                        Visibility="Collapsed">
                        <Grid ColumnSpacing="9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="ConfirmationTitleText" FontWeight="SemiBold" />
                                <TextBlock x:Name="ConfirmationMessageText" FontSize="11" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="6">
                                <Button Click="CancelConfirmation_Click" CornerRadius="6">
                                    <TextBlock Text="{Binding [common.cancel], Source={StaticResource Strings}}" />
                                </Button>
                                <Button x:Name="ConfirmOperationButton" Click="ConfirmOperationButton_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <InfoBar x:Name="ResultBar" IsClosable="True" IsOpen="False" />
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="BusyOverlay" Grid.ColumnSpan="2" Background="#66000000" Visibility="Collapsed">
                <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}" CornerRadius="9" Padding="18,12">
                    <StackPanel Orientation="Horizontal" Spacing="9">
                        <ProgressRing Width="24" Height="24" IsActive="True" />
                        <TextBlock x:Name="BusyText" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentDialog>
