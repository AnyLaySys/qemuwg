<Window
    x:Class="QemuWG.主窗"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:数据="using:QemuWG.数据"
    xmlns:界面="using:QemuWG.界面">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" SizeChanged="RootGrid_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid x:Name="TitleBarDragRegion" Grid.ColumnSpan="2" Background="Transparent">
            <StackPanel
                Margin="9,0,150,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                IsHitTestVisible="False"
                Orientation="Horizontal"
                Spacing="6">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource SidebarTextBrush}"
                    Text="QemuWG" />
                <Border
                    MaxWidth="180"
                    Padding="6,2"
                    VerticalAlignment="Center"
                    Background="{ThemeResource VersionBadgeBackgroundBrush}"
                    CornerRadius="3">
                    <TextBlock
                        x:Name="QemuVersionText"
                        FontSize="12"
                        Foreground="{ThemeResource VersionBadgeForegroundBrush}"
                        TextTrimming="CharacterEllipsis" />
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="0" Background="{ThemeResource SidebarBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="9" HorizontalAlignment="Center">
                <Button
                    x:Name="NewVmButton"
                    Click="NewVmButton_Click"
                    CornerRadius="6"
                    Foreground="{ThemeResource SidebarTextBrush}"
                    Style="{StaticResource 透明正方形按钮样式}"
                    ToolTipService.ToolTip="{Binding [main.newVm], Source={StaticResource Strings}}">
                    <SymbolIcon Symbol="Add" />
                </Button>
            </Grid>

            <ItemsControl
                x:Name="VmItems"
                Grid.Row="1"
                Margin="9,0"
                HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="界面:仿真侧栏项">
                        <Button
                            HorizontalAlignment="Center"
                            Background="{Binding 背景}"
                            Click="VmSidebarButton_Click"
                            CommandParameter="{Binding}"
                            CornerRadius="6"
                            Foreground="{Binding 前景}"
                            Style="{StaticResource 正方形按钮样式}">
                            <ToolTipService.ToolTip>
                                <StackPanel Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding 名称}" />
                                    <TextBlock FontSize="11" Text="{Binding 状态}" />
                                </StackPanel>
                            </ToolTipService.ToolTip>
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding 首字母}" />
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Row="2" Margin="9" HorizontalAlignment="Center" Spacing="4">
                <Button
                    x:Name="SettingsButton"
                    Click="SettingsButton_Click"
                    CornerRadius="6"
                    Foreground="{ThemeResource SidebarTextBrush}"
                    Style="{StaticResource 透明正方形按钮样式}"
                    ToolTipService.ToolTip="{Binding [main.settings], Source={StaticResource Strings}}">
                    <SymbolIcon Symbol="Setting" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid x:Name="LoadingView">
                <ProgressRing IsActive="True" />
            </Grid>

            <Grid x:Name="EmptyView" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                    <FontIcon FontSize="42" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE7F8;" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding [main.selectVm], Source={StaticResource Strings}}" />
                </StackPanel>
            </Grid>

            <Grid x:Name="DetailsView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,9,9,9" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock x:Name="VmNameText" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="VmStatusText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Spacing="6">
                        <StackPanel
                            x:Name="PowerActionsHost"
                            Orientation="Horizontal"
                            PointerEntered="PowerActionsHost_PointerEntered"
                            PointerExited="PowerActionsHost_PointerExited"
                            Spacing="6">
                            <Button
                                x:Name="PowerButton"
                                Click="PowerButton_Click"
                                CornerRadius="6"
                                PointerCanceled="PowerButton_PointerCanceled"
                                PointerCaptureLost="PowerButton_PointerCanceled"
                                PointerPressed="PowerButton_PointerPressed"
                                PointerReleased="PowerButton_PointerReleased"
                                Style="{StaticResource 强调正方形按钮样式}">
                                <FontIcon x:Name="PowerButtonIcon" Glyph="&#xE7E8;" />
                            </Button>
                            <StackPanel
                                x:Name="PowerSecondaryButtons"
                                Orientation="Horizontal"
                                Spacing="6"
                                PointerEntered="PowerActionsHost_PointerEntered"
                                PointerExited="PowerActionsHost_PointerExited"
                                Visibility="Collapsed">
                                <Button
                                    x:Name="PauseResumeButton"
                                    Click="PauseResumeButton_Click"
                                    CornerRadius="6"
                                    PointerEntered="PowerActionsHost_PointerEntered"
                                    PointerExited="PowerActionsHost_PointerExited"
                                    Style="{StaticResource 正方形按钮样式}">
                                    <FontIcon x:Name="PauseResumeIcon" Glyph="&#xE769;" />
                                </Button>
                                <Button
                                    x:Name="ResetButton"
                                    Click="ResetButton_Click"
                                    CornerRadius="6"
                                    PointerEntered="PowerActionsHost_PointerEntered"
                                    PointerExited="PowerActionsHost_PointerExited"
                                    Style="{StaticResource 正方形按钮样式}"
                                    ToolTipService.ToolTip="{Binding [qmp.reset], Source={StaticResource Strings}}">
                                    <SymbolIcon Symbol="Refresh" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <Button
                            x:Name="ScreenshotButton"
                            Click="ScreenshotButton_Click"
                            CornerRadius="6"
                            Style="{StaticResource 正方形按钮样式}"
                            ToolTipService.ToolTip="{Binding [qmp.screenshot], Source={StaticResource Strings}}">
                            <FontIcon Glyph="&#xE722;" />
                        </Button>
                        <Button x:Name="EditButton" Click="EditButton_Click" CornerRadius="6" Style="{StaticResource 正方形按钮样式}" ToolTipService.ToolTip="{Binding [main.editConfig], Source={StaticResource Strings}}">
                            <SymbolIcon Symbol="Edit" />
                        </Button>
                        <Button x:Name="VmSnapshotButton" Click="SnapshotManager_Click" CornerRadius="6" Style="{StaticResource 正方形按钮样式}" ToolTipService.ToolTip="{Binding [main.snapshotManager], Source={StaticResource Strings}}">
                            <FontIcon Foreground="#6F7FE8" Glyph="&#xE777;" />
                        </Button>
                        <Button x:Name="VmDiskManagerButton" Click="DiskManager_Click" CornerRadius="6" Style="{StaticResource 正方形按钮样式}" ToolTipService.ToolTip="{Binding [main.diskManager], Source={StaticResource Strings}}">
                            <FontIcon
                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                FontSize="24"
                                Foreground="#DF9835"
                                Glyph="&#xEDA2;" />
                        </Button>
                        <Button x:Name="VmFeaturesButton" Click="VmFeaturesButton_Click" CornerRadius="6" Style="{StaticResource 正方形按钮样式}" ToolTipService.ToolTip="{Binding [main.vmDeviceServices], Source={StaticResource Strings}}">
                            <FontIcon Foreground="#2AA7A1" Glyph="&#xE90F;" />
                        </Button>
                        <Button x:Name="VmFolderButton" Click="OpenFolder_Click" CornerRadius="6" Style="{StaticResource 正方形按钮样式}" ToolTipService.ToolTip="{Binding [main.openVmFolder], Source={StaticResource Strings}}">
                            <SymbolIcon Symbol="Folder" />
                        </Button>
                        <Button x:Name="VmLogButton" Click="OpenLog_Click" CornerRadius="6" Style="{StaticResource 正方形按钮样式}" ToolTipService.ToolTip="{Binding [main.openQemuLog], Source={StaticResource Strings}}">
                            <SymbolIcon Symbol="Document" />
                        </Button>
                        <Button x:Name="MoreButton" CornerRadius="6" Style="{StaticResource 正方形按钮样式}" ToolTipService.ToolTip="{Binding [main.more], Source={StaticResource Strings}}">
                            <SymbolIcon Symbol="More" />
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem x:Name="DeleteVmMenuItem" Click="DeleteButton_Click" Text="{Binding [main.deleteVm], Source={StaticResource Strings}}">
                                        <MenuFlyoutItem.Icon><SymbolIcon Symbol="Delete" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>

                <ScrollViewer
                    x:Name="DetailScrollViewer"
                    Grid.Row="1"
                    HorizontalContentAlignment="Stretch"
                    HorizontalScrollBarVisibility="Disabled"
                    HorizontalScrollMode="Disabled"
                    VerticalContentAlignment="Stretch"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Auto">
                <Grid x:Name="DetailBodyGrid" Margin="0,0,9,9" ColumnSpacing="14" RowSpacing="9">
                    <Grid.ChildrenTransitions>
                        <TransitionCollection>
                            <RepositionThemeTransition IsStaggeringEnabled="False" />
                        </TransitionCollection>
                    </Grid.ChildrenTransitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="DetailLeftColumn" Width="0.32*" />
                        <ColumnDefinition x:Name="DetailRightColumn" Width="0.68*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="*" /></Grid.RowDefinitions>

                    <Grid x:Name="VmSummaryColumn">
                    <Border
                        x:Name="ConfigurationCard"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="44" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Margin="14,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding [main.configuration], Source={StaticResource Strings}}" />
                            <ListView
                                x:Name="DeviceList"
                                Grid.Row="1"
                                Padding="6,0,6,6"
                                Background="Transparent"
                                BorderThickness="0"
                                IsItemClickEnabled="False"
                                ItemsSource="{x:Bind DeviceSummaries}"
                                SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource 圆角列表项基础样式}">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,1" />
                                        <Setter Property="CornerRadius" Value="3" />
                                        <Setter Property="MinHeight" Value="48" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="数据:设备摘要">
                                        <Grid Padding="9,3" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon VerticalAlignment="Center" FontSize="16" Foreground="{x:Bind IconBrush}" Glyph="{x:Bind Glyph}" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Title}" />
                                                <TextBlock MaxLines="1" Text="{x:Bind Value}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                    </Grid>

                    <Grid x:Name="VmContentColumn" Grid.Column="1">
                    <Border
                        x:Name="DisplayPane"
                        Background="{ThemeResource DisplayBackgroundBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid x:Name="DisplayHeader" Height="44" Padding="9,0">
                                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding [main.display], Source={StaticResource Strings}}" />
                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="DisplayBackendText" VerticalAlignment="Center" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <Button
                                        x:Name="DetachDisplayButton"
                                        Click="DetachDisplayButton_Click"
                                        CornerRadius="3"
                                        Style="{StaticResource 正方形按钮样式}"
                                        ToolTipService.ToolTip="{Binding [main.detachDisplay], Source={StaticResource Strings}}">
                                        <FontIcon FontSize="13" Glyph="&#xE8A7;" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <Grid x:Name="DisplaySurface" Grid.Row="1">
                                <Grid
                                    x:Name="EmbeddedDisplayHost"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Background="{ThemeResource DisplayBackgroundBrush}">
                                    <Viewbox Stretch="Uniform">
                                        <SwapChainPanel
                                            x:Name="EmbeddedDisplayPanel"
                                            IsTabStop="True"
                                            KeyDown="EmbeddedDisplayPanel_KeyDown"
                                            KeyUp="EmbeddedDisplayPanel_KeyUp"
                                            LostFocus="EmbeddedDisplayPanel_LostFocus"
                                            PointerCanceled="EmbeddedDisplayPanel_PointerCanceled"
                                            PointerCaptureLost="EmbeddedDisplayPanel_PointerCaptureLost"
                                            PointerEntered="EmbeddedDisplayPanel_PointerEntered"
                                            PointerExited="EmbeddedDisplayPanel_PointerExited"
                                            PointerMoved="EmbeddedDisplayPanel_PointerMoved"
                                            PointerPressed="EmbeddedDisplayPanel_PointerPressed"
                                            PointerReleased="EmbeddedDisplayPanel_PointerReleased"
                                            PointerWheelChanged="EmbeddedDisplayPanel_PointerWheelChanged"
                                            RightTapped="EmbeddedDisplayPanel_RightTapped"
                                            Visibility="Collapsed" />
                                    </Viewbox>
                                    <Grid IsHitTestVisible="False">
                                        <Path
                                            Width="6"
                                            Height="6"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Data="M 0,0 L 6,0 A 6,6 0 0 0 0,6 Z"
                                            Fill="{ThemeResource DisplayBackgroundBrush}" />
                                        <Path
                                            Width="6"
                                            Height="6"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Data="M 0,0 L 6,0 A 6,6 0 0 0 0,6 Z"
                                            Fill="{ThemeResource DisplayBackgroundBrush}"
                                            RenderTransformOrigin="0.5,0.5">
                                            <Path.RenderTransform><RotateTransform Angle="90" /></Path.RenderTransform>
                                        </Path>
                                    </Grid>
                                </Grid>
                                <StackPanel x:Name="DisplayFallback" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                    <FontIcon FontSize="52" Foreground="#5C6673" Glyph="&#xE740;" />
                                    <TextBlock x:Name="DisplayStateText" HorizontalAlignment="Center" Foreground="{ThemeResource DisplayTextBrush}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border
                        x:Name="VmFeaturesPane"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="44" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Padding="9,0" ColumnSpacing="9">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Click="BackToDisplayButton_Click" CornerRadius="3" Style="{StaticResource 正方形按钮样式}" ToolTipService.ToolTip="{Binding [main.backToDisplay], Source={StaticResource Strings}}">
                                    <FontIcon FontSize="13" Glyph="&#xE72B;" />
                                </Button>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding [main.vmDeviceServices], Source={StaticResource Strings}}" />
                                    <TextBlock x:Name="VmFeaturesContextText" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                            <ContentControl x:Name="VmFeaturesHost" Grid.Row="1" />
                        </Grid>
                    </Border>
                    </Grid>
                </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
