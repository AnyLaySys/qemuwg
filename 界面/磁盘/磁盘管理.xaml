<ContentDialog
    x:Class="QemuWG.界面.磁盘管理"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:数据="using:QemuWG.数据"
    CornerRadius="9"
    CloseButtonText="{Binding [common.done], Source={StaticResource Strings}}">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1080</x:Double>
    </ContentDialog.Resources>

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.22*" />
            <ColumnDefinition Width="0.78*" />
        </Grid.ColumnDefinitions>

        <Border
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Margin="14,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding [disk.operations], Source={StaticResource Strings}}" />
                <ListView
                    x:Name="CommandList"
                    Grid.Row="1"
                    Margin="6,0,6,6"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectionChanged="CommandList_SelectionChanged"
                    SelectionMode="Single">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource 圆角列表项基础样式}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="MinHeight" Value="43" />
                            <Setter Property="Padding" Value="6,3" />
                            <Setter Property="Margin" Value="0,1" />
                            <Setter Property="CornerRadius" Value="3" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="数据:磁盘命令">
                            <Grid ColumnSpacing="9">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon VerticalAlignment="Center" FontSize="15" Foreground="{x:Bind IconBrush}" Glyph="{x:Bind Glyph}" />
                                <StackPanel Grid.Column="1" Spacing="1">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                    <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Description}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="0.3*" />
            </Grid.RowDefinitions>

            <Grid>
                <StackPanel Spacing="2">
                    <TextBlock x:Name="DiskNameText" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="DiskInfoText" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Spacing="6">
                    <Button x:Name="CancelRunButton" Click="CancelRunButton_Click" CornerRadius="6" Visibility="Collapsed">
                        <TextBlock Text="{Binding [common.cancel], Source={StaticResource Strings}}" />
                    </Button>
                    <Button x:Name="ExecuteButton" Click="ExecuteButton_Click" CornerRadius="6" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <SymbolIcon Symbol="Play" />
                            <TextBlock x:Name="ExecuteButtonText" Text="{Binding [common.execute], Source={StaticResource Strings}}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="38" Height="38" Background="{ThemeResource AccentFillColorSecondaryBrush}" CornerRadius="6">
                    <FontIcon x:Name="CommandIcon" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="17" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                    <TextBlock x:Name="CommandTitleText" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock x:Name="CommandDescriptionText" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <Grid x:Name="FormGrid" ColumnSpacing="10" RowSpacing="9">
                        <Grid.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="6" IsStaggeringEnabled="True" />
                                <RepositionThemeTransition IsStaggeringEnabled="False" />
                            </TransitionCollection>
                        </Grid.ChildrenTransitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                    <Expander x:Name="AdvancedExpander" Header="{Binding [disk.advanced], Source={StaticResource Strings}}" IsExpanded="False">
                        <StackPanel x:Name="AdvancedFieldsPanel" Padding="0,6,0,0" Spacing="9">
                            <StackPanel.ChildrenTransitions>
                                <TransitionCollection><EntranceThemeTransition FromVerticalOffset="6" IsStaggeringEnabled="True" /></TransitionCollection>
                            </StackPanel.ChildrenTransitions>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <InfoBar
                x:Name="SafetyInfo"
                Grid.Row="3"
                IsClosable="False"
                IsOpen="False"
                Severity="Warning" />

            <Expander Grid.Row="4" Header="{Binding [disk.commandPreview], Source={StaticResource Strings}}" IsExpanded="False">
                <TextBox
                    x:Name="CommandPreviewBox"
                    FontFamily="Cascadia Mono, Consolas"
                    FontSize="11"
                    IsReadOnly="True"
                    TextWrapping="NoWrap" />
            </Expander>

            <Grid Grid.Row="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding [common.output], Source={StaticResource Strings}}" />
                    <TextBlock x:Name="ExitCodeText" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
                <TextBox
                    x:Name="OutputBox"
                    Grid.Row="1"
                    AcceptsReturn="True"
                    FontFamily="Cascadia Mono, Consolas"
                    FontSize="11"
                    IsReadOnly="True"
                    TextWrapping="Wrap" />
                <ProgressBar x:Name="RunProgress" Grid.Row="1" VerticalAlignment="Top" IsIndeterminate="True" Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Grid>
</ContentDialog>
