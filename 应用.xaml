<Application
    x:Class="QemuWG.应用"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:服务="using:QemuWG.服务">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <CornerRadius x:Key="GridViewItemCornerRadius">6</CornerRadius>
                    <CornerRadius x:Key="ListViewItemCornerRadius">6</CornerRadius>
                    <CornerRadius x:Key="ListViewItemSelectionIndicatorCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="ComboBoxHiglightBorderCornerRadius">6</CornerRadius>
                    <CornerRadius x:Key="ComboBoxDropDownButtonBackgroundCornerRadius">6</CornerRadius>
                    <CornerRadius x:Key="ComboBoxItemCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="ComboBoxItemPillCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="InfoBarActionButtonCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="ProgressBarCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="ProgressBarTrackCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="SliderTrackCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="SliderThumbCornerRadius">6</CornerRadius>
                    <CornerRadius x:Key="ThumbCornerRadius">3</CornerRadius>
                    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="SidebarTextBrush" Color="#1A1A1A" />
                    <SolidColorBrush x:Key="SidebarSecondaryTextBrush" Color="#646464" />
                    <SolidColorBrush x:Key="VersionBadgeBackgroundBrush" Color="#DCEBFF" />
                    <SolidColorBrush x:Key="VersionBadgeForegroundBrush" Color="#145DA0" />
                    <SolidColorBrush x:Key="VmIconBackgroundBrush" Color="#DCE8F8" />
                    <SolidColorBrush x:Key="VmIconForegroundBrush" Color="#245A9C" />
                    <SolidColorBrush x:Key="DisplayBackgroundBrush" Color="#F6F6F6" />
                    <SolidColorBrush x:Key="DisplayFooterBrush" Color="#EAEAEA" />
                    <SolidColorBrush x:Key="DisplayTextBrush" Color="#505050" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <CornerRadius x:Key="GridViewItemCornerRadius">6</CornerRadius>
                    <CornerRadius x:Key="ListViewItemCornerRadius">6</CornerRadius>
                    <CornerRadius x:Key="ListViewItemSelectionIndicatorCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="ComboBoxHiglightBorderCornerRadius">6</CornerRadius>
                    <CornerRadius x:Key="ComboBoxDropDownButtonBackgroundCornerRadius">6</CornerRadius>
                    <CornerRadius x:Key="ComboBoxItemCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="ComboBoxItemPillCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="InfoBarActionButtonCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="ProgressBarCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="ProgressBarTrackCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="SliderTrackCornerRadius">3</CornerRadius>
                    <CornerRadius x:Key="SliderThumbCornerRadius">6</CornerRadius>
                    <CornerRadius x:Key="ThumbCornerRadius">3</CornerRadius>
                    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="SidebarTextBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="SidebarSecondaryTextBrush" Color="#AAB0B8" />
                    <SolidColorBrush x:Key="VersionBadgeBackgroundBrush" Color="#294A70" />
                    <SolidColorBrush x:Key="VersionBadgeForegroundBrush" Color="#D8E9FF" />
                    <SolidColorBrush x:Key="VmIconBackgroundBrush" Color="#253046" />
                    <SolidColorBrush x:Key="VmIconForegroundBrush" Color="#8AB4F8" />
                    <SolidColorBrush x:Key="DisplayBackgroundBrush" Color="#101215" />
                    <SolidColorBrush x:Key="DisplayFooterBrush" Color="#171A1F" />
                    <SolidColorBrush x:Key="DisplayTextBrush" Color="#AAB0B8" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
            <CornerRadius x:Key="OverlayCornerRadius">9</CornerRadius>
            <Thickness x:Key="ContentDialogPadding">9</Thickness>
            <服务:语言服务 x:Key="Strings" />
            <Style x:Key="圆角列表项基础样式" TargetType="ListViewItem">
                <Setter Property="Background" Value="{ThemeResource ListViewItemBackground}" />
                <Setter Property="Foreground" Value="{ThemeResource ListViewItemForeground}" />
                <Setter Property="FontFamily" Value="{ThemeResource ContentControlThemeFontFamily}" />
                <Setter Property="FontSize" Value="{ThemeResource ControlContentThemeFontSize}" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="MinWidth" Value="{ThemeResource ListViewItemMinWidth}" />
                <Setter Property="MinHeight" Value="{ThemeResource ListViewItemMinHeight}" />
                <Setter Property="Padding" Value="16,0,12,0" />
                <Setter Property="CornerRadius" Value="3" />
                <Setter Property="TabNavigation" Value="Local" />
                <Setter Property="IsHoldingEnabled" Value="True" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
                <Setter Property="FocusVisualMargin" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Border
                                x:Name="项目背景"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Control.IsTemplateFocusTarget="True"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="项目背景.Background" Value="{ThemeResource ListViewItemBackgroundPointerOver}" />
                                                <Setter Target="内容.Foreground" Value="{ThemeResource ListViewItemForegroundPointerOver}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="项目背景.Background" Value="{ThemeResource ListViewItemBackgroundPressed}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Target="项目背景.Background" Value="{ThemeResource ListViewItemBackgroundSelected}" />
                                                <Setter Target="内容.Foreground" Value="{ThemeResource ListViewItemForegroundSelected}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="PointerOverSelected">
                                            <VisualState.Setters>
                                                <Setter Target="项目背景.Background" Value="{ThemeResource ListViewItemBackgroundSelectedPointerOver}" />
                                                <Setter Target="内容.Foreground" Value="{ThemeResource ListViewItemForegroundSelected}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="PressedSelected">
                                            <VisualState.Setters>
                                                <Setter Target="项目背景.Background" Value="{ThemeResource ListViewItemBackgroundSelectedPressed}" />
                                                <Setter Target="内容.Foreground" Value="{ThemeResource ListViewItemForegroundSelected}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="项目背景.Opacity" Value="{ThemeResource ListViewItemDisabledThemeOpacity}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="SelectedDisabled">
                                            <VisualState.Setters>
                                                <Setter Target="项目背景.Background" Value="{ThemeResource ListViewItemBackgroundSelectedDisabled}" />
                                                <Setter Target="项目背景.Opacity" Value="{ThemeResource ListViewItemDisabledThemeOpacity}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter
                                    x:Name="内容"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    ContentTransitions="{TemplateBinding ContentTransitions}"
                                    Foreground="{TemplateBinding Foreground}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="ListViewItem" BasedOn="{StaticResource 圆角列表项基础样式}" />
            <Style x:Key="宽行圆角列表项样式" TargetType="ListViewItem" BasedOn="{StaticResource 圆角列表项基础样式}">
                <Setter Property="CornerRadius" Value="6" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
